{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/source-acquisition/v1/crawl-policy.schema.json",
  "title": "CrawlPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyId",
    "allowedDomains",
    "maxDepth",
    "maxPages",
    "maxConcurrency",
    "requestTimeoutMs",
    "respectRobotsTxt",
    "renderJavaScript",
    "retry"
  ],
  "properties": {
    "schemaVersion": {
      "const": "source-acquisition.v1"
    },
    "policyId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "allowedDomains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9.-]+$"
      }
    },
    "maxDepth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 25
    },
    "maxPages": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "maxConcurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "requestTimeoutMs": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 120000
    },
    "respectRobotsTxt": {
      "type": "boolean"
    },
    "renderJavaScript": {
      "type": "boolean"
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAttempts",
        "backoffMs"
      ],
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "backoffMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60000
        }
      }
    }
  }
}

