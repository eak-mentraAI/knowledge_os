{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/source-acquisition/v1/crawl-inventory.schema.json",
  "title": "CrawlInventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "crawlJobId",
    "sourceId",
    "status",
    "startedAt",
    "totals",
    "records",
    "checkpoint"
  ],
  "properties": {
    "schemaVersion": {
      "const": "source-acquisition.v1"
    },
    "crawlJobId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,120}$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "completed_with_errors",
        "failed",
        "canceled"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discovered",
        "fetched",
        "skipped",
        "failed",
        "blocked"
      ],
      "properties": {
        "discovered": {
          "type": "integer",
          "minimum": 0
        },
        "fetched": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cursor",
        "contentHash"
      ],
      "properties": {
        "cursor": {
          "type": [
            "string",
            "null"
          ]
        },
        "contentHash": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}

