{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/source-acquisition/v1/source-definition.schema.json",
  "title": "SourceDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceId",
    "name",
    "sourceType",
    "location",
    "domainPack",
    "crawlPolicy",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "source-acquisition.v1"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "url_list",
        "sitemap",
        "documentation_site",
        "github",
        "confluence",
        "sharepoint",
        "pdf_collection",
        "markdown_repository"
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "label": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "domainPack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
        }
      }
    },
    "crawlPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyId",
        "allowedDomains",
        "maxDepth",
        "maxPages",
        "maxConcurrency",
        "requestTimeoutMs",
        "respectRobotsTxt",
        "renderJavaScript",
        "retry"
      ],
      "properties": {
        "policyId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "allowedDomains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9.-]+$"
          }
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 25
        },
        "maxPages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "maxConcurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000
        },
        "respectRobotsTxt": {
          "type": "boolean"
        },
        "renderJavaScript": {
          "type": "boolean"
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "maxAttempts",
            "backoffMs"
          ],
          "properties": {
            "maxAttempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "backoffMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 60000
            }
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string",
      "maxLength": 200
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  }
}

