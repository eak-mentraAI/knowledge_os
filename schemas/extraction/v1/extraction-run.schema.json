{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/extraction/v1/extraction-run.schema.json",
  "title": "ExtractionRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "extractionVersion",
    "domainPackId",
    "documentId",
    "status",
    "nodeCandidates",
    "edgeCandidates",
    "metrics",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "extraction.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "extractionVersion": {
      "type": "string",
      "minLength": 1
    },
    "domainPackId": {
      "type": "string",
      "minLength": 1
    },
    "documentId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "completed_with_errors", "failed"]
    },
    "nodeCandidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/NodeCandidate"
      }
    },
    "edgeCandidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EdgeCandidate"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentsProcessed",
        "nodeCandidateCount",
        "edgeCandidateCount",
        "failedDocumentCount"
      ],
      "properties": {
        "documentsProcessed": {
          "type": "integer",
          "minimum": 0
        },
        "nodeCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "edgeCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "failedDocumentCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "EvidenceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentId",
        "sourceRecordId",
        "startOffset",
        "endOffset",
        "quote"
      ],
      "properties": {
        "documentId": {
          "type": "string"
        },
        "sourceRecordId": {
          "type": "string"
        },
        "startOffset": {
          "type": "integer",
          "minimum": 0
        },
        "endOffset": {
          "type": "integer",
          "minimum": 0
        },
        "quote": {
          "type": "string"
        }
      }
    },
    "NodeCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "nodeType",
        "name",
        "sourceDocumentId",
        "sourceRecordId",
        "evidenceSpans",
        "confidence",
        "extractionVersion",
        "properties"
      ],
      "properties": {
        "candidateId": {
          "type": "string"
        },
        "nodeType": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sourceDocumentId": {
          "type": "string"
        },
        "sourceRecordId": {
          "type": "string"
        },
        "evidenceSpans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/EvidenceSpan"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "extractionVersion": {
          "type": "string"
        },
        "properties": {
          "type": "object"
        }
      }
    },
    "EdgeCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "edgeType",
        "sourceName",
        "targetName",
        "sourceDocumentId",
        "sourceRecordId",
        "evidenceSpans",
        "confidence",
        "extractionVersion",
        "properties"
      ],
      "properties": {
        "candidateId": {
          "type": "string"
        },
        "edgeType": {
          "type": "string"
        },
        "sourceName": {
          "type": "string"
        },
        "targetName": {
          "type": "string"
        },
        "sourceDocumentId": {
          "type": "string"
        },
        "sourceRecordId": {
          "type": "string"
        },
        "evidenceSpans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/EvidenceSpan"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "extractionVersion": {
          "type": "string"
        },
        "properties": {
          "type": "object"
        }
      }
    }
  }
}

