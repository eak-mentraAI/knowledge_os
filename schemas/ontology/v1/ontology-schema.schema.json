{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/ontology/v1/ontology-schema.schema.json",
  "title": "OntologySchema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ontologyId",
    "version",
    "description",
    "nodeTypes",
    "edgeTypes",
    "extensionRules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ontology.v1"
    },
    "ontologyId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+){0,2}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "nodeTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/NodeType"
      }
    },
    "edgeTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/EdgeType"
      }
    },
    "extensionRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domainPacksMayAddTypes",
        "domainPacksMayRedefineBaseTypes",
        "requiresMigrationNotes"
      ],
      "properties": {
        "domainPacksMayAddTypes": {
          "type": "boolean"
        },
        "domainPacksMayRedefineBaseTypes": {
          "type": "boolean"
        },
        "requiresMigrationNotes": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "NodeType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "description",
        "requiredProperties"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9]+$"
        },
        "category": {
          "type": "string",
          "enum": [
            "business",
            "knowledge",
            "source",
            "security",
            "governance",
            "execution"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "requiredProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "EdgeType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "sourceTypes",
        "targetTypes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "sourceTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "targetTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

