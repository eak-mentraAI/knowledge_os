{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/document-processing/v1/canonical-document.schema.json",
  "title": "CanonicalDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentId",
    "sourceRecordId",
    "sourceId",
    "url",
    "title",
    "contentHashSha256",
    "processingStatus",
    "text",
    "sections",
    "links",
    "tables",
    "quality",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "document-processing.v1"
    },
    "documentId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,140}$"
    },
    "sourceRecordId": {
      "type": "string",
      "minLength": 1
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "contentHashSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "processingStatus": {
      "type": "string",
      "enum": [
        "processed",
        "empty",
        "failed"
      ]
    },
    "text": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentSection"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentLink"
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentTable"
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emptyContent",
        "textLength",
        "parseWarnings"
      ],
      "properties": {
        "emptyContent": {
          "type": "boolean"
        },
        "textLength": {
          "type": "integer",
          "minimum": 0
        },
        "parseWarnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "EvidenceSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "documentId",
        "sourceRecordId",
        "startOffset",
        "endOffset",
        "quote"
      ],
      "properties": {
        "documentId": {
          "type": "string"
        },
        "sourceRecordId": {
          "type": "string"
        },
        "startOffset": {
          "type": "integer",
          "minimum": 0
        },
        "endOffset": {
          "type": "integer",
          "minimum": 0
        },
        "quote": {
          "type": "string"
        }
      }
    },
    "DocumentSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sectionId",
        "headingLevel",
        "title",
        "path",
        "text",
        "evidenceSpans"
      ],
      "properties": {
        "sectionId": {
          "type": "string"
        },
        "headingLevel": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "title": {
          "type": "string"
        },
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "text": {
          "type": "string"
        },
        "evidenceSpans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceSpan"
          }
        }
      }
    },
    "DocumentLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "text",
        "evidenceSpan"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "evidenceSpan": {
          "$ref": "#/$defs/EvidenceSpan"
        }
      }
    },
    "DocumentTable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caption",
        "headers",
        "rows",
        "evidenceSpan"
      ],
      "properties": {
        "caption": {
          "type": "string"
        },
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "evidenceSpan": {
          "$ref": "#/$defs/EvidenceSpan"
        }
      }
    }
  }
}

